// =============================================================
// Jenkinsfile - Order API CI/CD 파이프라인
// 위치: 소스 코드 리포지토리 루트 (order-api/Jenkinsfile)
//
// 파이프라인 흐름:
//   1. 소스 코드 체크아웃 (Gitea)
//   2. 테스트 실행 (Maven)
//   3. Docker 이미지 빌드 및 Harbor Push
//   4. Harbor Trivy 취약점 스캔
//   5. Ops 리포지토리 이미지 태그 업데이트
//   6. ArgoCD가 변경을 감지하여 자동 배포
//
// 공유 라이브러리(Shared Library)를 사용하여 공통 로직을 모듈화한다.
// =============================================================

// Shared Library 로드 (Jenkins 전역 설정에서 자동 로드되므로 선택적)
@Library('gitops-shared-lib') _

pipeline {
    // ── 에이전트 설정 ────────────────────────────────────────
    agent {
        kubernetes {
            // K3s 클러스터 내 동적 Pod 에이전트 사용
            yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    app: jenkins-agent
spec:
  # Harbor imagePullSecrets 설정
  imagePullSecrets:
    - name: harbor-credentials

  containers:
    # ── Maven 빌드 컨테이너 ─────────────────────────────────
    - name: maven
      image: maven:3.9.6-eclipse-temurin-21
      command: ['sleep']
      args: ['99d']
      resources:
        requests:
          cpu: 500m
          memory: 1Gi
        limits:
          cpu: 2000m
          memory: 2Gi
      volumeMounts:
        # Maven 로컬 캐시를 Pod 간 공유하여 빌드 속도 향상
        - name: maven-cache
          mountPath: /root/.m2

    # ── Docker 빌드 컨테이너 (DooD: Docker-outside-of-Docker) ─
    - name: docker
      image: docker:24.0.7-dind
      command: ['sleep']
      args: ['99d']
      securityContext:
        # Docker 소켓 접근을 위한 권한
        privileged: true
      volumeMounts:
        - name: docker-sock
          mountPath: /var/run/docker.sock

  volumes:
    # 호스트 Docker 소켓 마운트 (DooD 방식)
    - name: docker-sock
      hostPath:
        path: /var/run/docker.sock
    # Maven 빌드 캐시 (PVC 사용)
    - name: maven-cache
      persistentVolumeClaim:
        claimName: maven-cache-pvc
"""
        }
    }

    // ── 환경 변수 설정 ────────────────────────────────────────
    environment {
        // Harbor 레지스트리 설정
        HARBOR_URL        = 'harbor.local'
        HARBOR_PROJECT    = 'gitops'
        IMAGE_NAME        = 'order-api'

        // 이미지 태그: 브랜치명-커밋해시 조합 (고유성 보장)
        IMAGE_TAG         = "${env.BRANCH_NAME}-${env.GIT_COMMIT.take(8)}"

        // Gitea Ops 리포지토리 URL
        OPS_REPO_URL      = 'http://gitea.local/gitops/order-ops.git'

        // 배포 환경 결정 (main 브랜치 → dev, release 브랜치 → prod)
        DEPLOY_ENV        = "${env.BRANCH_NAME == 'main' ? 'dev' : (env.BRANCH_NAME.startsWith('release/') ? 'prod' : 'dev')}"
    }

    // ── 빌드 옵션 ─────────────────────────────────────────────
    options {
        // 빌드 타임아웃: 30분
        timeout(time: 30, unit: 'MINUTES')
        // 빌드 이력 유지: 최근 20개
        buildDiscarder(logRotator(numToKeepStr: '20'))
        // 동일 브랜치 동시 빌드 방지
        disableConcurrentBuilds()
        // 콘솔 출력 타임스탬프 추가
        timestamps()
        // ANSI 색상 출력
        ansiColor('xterm')
    }

    // ── 파이프라인 스테이지 ────────────────────────────────────
    stages {

        // ── Stage 1: 소스 코드 체크아웃 ──────────────────────
        stage('🔍 Checkout') {
            steps {
                echo "📥 소스 코드 체크아웃 중..."
                checkout scm

                script {
                    // 커밋 정보를 환경변수에 저장
                    env.GIT_COMMIT_MSG = sh(
                        script: 'git log -1 --pretty=%B',
                        returnStdout: true
                    ).trim()
                    env.GIT_AUTHOR = sh(
                        script: 'git log -1 --pretty=%an',
                        returnStdout: true
                    ).trim()

                    echo "   커밋 메시지: ${env.GIT_COMMIT_MSG}"
                    echo "   작성자: ${env.GIT_AUTHOR}"
                    echo "   이미지 태그: ${env.IMAGE_TAG}"
                    echo "   배포 환경: ${env.DEPLOY_ENV}"
                }
            }
        }

        // ── Stage 2: 유닛 테스트 ─────────────────────────────
        stage('🧪 Unit Test') {
            steps {
                container('maven') {
                    echo "🧪 Maven 유닛 테스트 실행..."
                    sh """
                        mvn clean test \
                            -Dmaven.test.failure.ignore=false \
                            -B -q
                    """
                }
            }
            post {
                always {
                    // JUnit 테스트 결과 수집 및 Jenkins에 표시
                    junit(
                        testResults: '**/target/surefire-reports/*.xml',
                        allowEmptyResults: false
                    )
                }
            }
        }

        // ── Stage 3: 코드 품질 검사 (선택적) ─────────────────
        stage('📊 Code Quality') {
            when {
                // main 브랜치 또는 PR에서만 실행
                anyOf {
                    branch 'main'
                    changeRequest()
                }
            }
            steps {
                container('maven') {
                    echo "📊 SonarQube 코드 품질 검사..."
                    // SonarQube 연동 시 활성화
                    // withSonarQubeEnv('sonarqube') {
                    //     sh 'mvn sonar:sonar'
                    // }
                    echo "ℹ️  SonarQube 미설정 - 건너뜁니다."
                }
            }
        }

        // ── Stage 4: 애플리케이션 빌드 ───────────────────────
        stage('🔨 Build') {
            steps {
                container('maven') {
                    echo "🔨 Maven 빌드 (JAR 패키징)..."
                    sh """
                        mvn clean package \
                            -DskipTests \
                            -B -q
                    """
                    // 빌드된 JAR 파일 확인
                    sh 'ls -lh target/*.jar'
                }
            }
        }

        // ── Stage 5: Docker 이미지 빌드 & Harbor Push ────────
        stage('🐳 Build & Push Image') {
            steps {
                container('docker') {
                    script {
                        echo "🐳 Docker 이미지 빌드 및 Harbor Push..."

                        // Shared Library의 buildAndPushImage 함수 호출
                        pipelineUtils.buildAndPushImage([
                            imageName    : env.IMAGE_NAME,
                            imageTag     : env.IMAGE_TAG,
                            harborUrl    : env.HARBOR_URL,
                            harborProject: env.HARBOR_PROJECT,
                            credentialsId: 'harbor-credentials',
                            dockerfile   : './Dockerfile',
                            context      : '.'
                        ])
                    }
                }
            }
        }

        // ── Stage 6: 취약점 스캔 (Harbor Trivy) ─────────────
        stage('🔍 Vulnerability Scan') {
            steps {
                script {
                    echo "🔍 Harbor Trivy 취약점 스캔 대기 중..."

                    // Trivy 스캔이 완료될 때까지 대기 후 결과 검증
                    pipelineUtils.checkVulnerabilities([
                        harborUrl    : env.HARBOR_URL,
                        harborProject: env.HARBOR_PROJECT,
                        imageName    : env.IMAGE_NAME,
                        imageTag     : env.IMAGE_TAG,
                        failOnCritical: true   // CRITICAL 취약점 발견 시 파이프라인 실패
                    ])
                }
            }
        }

        // ── Stage 7: Ops 리포지토리 이미지 태그 업데이트 ──────
        stage('🔄 Update Ops Repo') {
            when {
                // main 또는 release 브랜치에서만 Ops 리포지토리 업데이트
                anyOf {
                    branch 'main'
                    expression { return env.BRANCH_NAME.startsWith('release/') }
                }
            }
            steps {
                script {
                    echo "🔄 Ops 리포지토리 이미지 태그 업데이트: ${env.DEPLOY_ENV}"

                    // Shared Library의 updateOpsRepo 함수 호출
                    pipelineUtils.updateOpsRepo([
                        opsRepoUrl  : env.OPS_REPO_URL,
                        imageTag    : env.IMAGE_TAG,
                        environment : env.DEPLOY_ENV,
                        credentialsId: 'gitea-ops-credentials'
                    ])

                    echo "✅ ArgoCD가 변경을 감지하여 자동 배포를 시작합니다."
                }
            }
        }

        // ── Stage 8: 배포 완료 알림 ──────────────────────────
        stage('📢 Notify') {
            steps {
                script {
                    def fullImage = "${env.HARBOR_URL}/${env.HARBOR_PROJECT}/${env.IMAGE_NAME}:${env.IMAGE_TAG}"
                    echo """
╔═══════════════════════════════════════════════════╗
║ ✅ CI 파이프라인 완료!                               ║
╠═══════════════════════════════════════════════════╣
║ 이미지    : ${fullImage}
║ 환경      : ${env.DEPLOY_ENV}
║ 브랜치    : ${env.BRANCH_NAME}
║ 커밋      : ${env.GIT_COMMIT.take(8)}
╚═══════════════════════════════════════════════════╝
                    """

                    // Slack 알림 (선택적)
                    pipelineUtils.notifySlack([
                        channel: '#gitops-deploy',
                        color  : 'good',
                        message: "✅ *Order API 빌드 성공*\n이미지: `${fullImage}`\n환경: `${env.DEPLOY_ENV}`"
                    ])
                }
            }
        }
    }

    // ── 파이프라인 완료 후 처리 ───────────────────────────────
    post {
        success {
            echo "🎉 파이프라인 성공!"
        }
        failure {
            echo "❌ 파이프라인 실패!"
            script {
                pipelineUtils.notifySlack([
                    channel: '#gitops-alerts',
                    color  : 'danger',
                    message: "❌ *Order API 빌드 실패*\n브랜치: `${env.BRANCH_NAME}`\n커밋: `${env.GIT_COMMIT.take(8)}`"
                ])
            }
        }
        always {
            // 워크스페이스 정리 (디스크 절약)
            cleanWs()
        }
    }
}
