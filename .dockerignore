# =============================================================
# GitOps Pipeline - .dockerignore
# =============================================================

# ── Git 메타데이터 ────────────────────────────────────────────
.git/
.gitignore

# ── 문서 / 산출물 ─────────────────────────────────────────────
docs/
README.md
*.md

# ── 개발 환경 ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp

# ── 환경 변수 ─────────────────────────────────────────────────
.env
.env.*
secrets/

# ── Java 빌드 캐시 (이미지 내부에서 빌드 시 불필요) ──────────
target/
*.log

# ── Docker Compose 관련 ──────────────────────────────────────
docker-compose*.yml
Dockerfile*

# ── 테스트 설정 ───────────────────────────────────────────────
**/test/
