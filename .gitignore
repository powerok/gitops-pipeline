# =============================================================
# GitOps Pipeline - .gitignore
# =============================================================

# ── 시크릿 / 인증 정보 ──────────────────────────────────────
*.key
*.pem
*.crt
*.p12
*.pfx
secrets/
.secrets/
*-secret.yaml
*-secret.yml
kubeconfig
.kubeconfig

# ── 환경 설정 파일 ──────────────────────────────────────────
.env
.env.*
!.env.example
*.local

# ── Helm 빌드 산출물 ────────────────────────────────────────
charts/*.tgz
*.lock

# ── OS 메타데이터 ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── IDE / 에디터 ─────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── 로그 / 임시 파일 ─────────────────────────────────────────
*.log
tmp/
temp/

# ── Java / Spring Boot 빌드 산출물 ───────────────────────────
target/
*.class
*.jar
*.war

# ── Docker ───────────────────────────────────────────────────
.dockerignore.bak
